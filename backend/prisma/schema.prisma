generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_id        Int            @id @default(autoincrement())
  username       String         @unique
  email          String         @unique
  password       String
  firstname      String?
  lastname       String?
  nickname       String?
  gender         String?
  weight         Float?
  height         Float?
  daily_cal_goal Float?
  profile_img    String?
  createdAt      DateTime       @default(now())

  // ความสัมพันธ์เเต่ละฟิลด์ เเม่รู้จักลุกนี้ลูกชั้นนะ 
  DailyLogs      DailyLog[]
  StepLogs       StepLog[]
  ExerciseLogs   ExercisesLog[]
}

model FoodLibrary {
  food_id      Int        @id @default(autoincrement())
  food_image   String?
  food_name    String
  category     String
  calories     Int
  protein      Int
  carb         Int
  fat          Int
  sugar        Int
  cholesterol  Int
  sodium       Int
  ai_labels    String?  
  serving_size Float
  unit_name    String
  DailyLogs    DailyLog[] 
}

model DailyLog {
  log_id          Int          @id @default(autoincrement())
  user            User         @relation(fields: [user_id], references: [user_id])
  user_id         Int
  food            FoodLibrary? @relation(fields: [food_id], references: [food_id])
  food_id         Int?
  amount_eaten    Float        @default(1.0)
  logged_calories Int
  meal_type       String
  log_date        DateTime     @default(now())
  image_url       String?
}

model Article {
  article_id      Int      @id @default(autoincrement())
  title           String
  article_url     String
  thumbnail_url   String
  credit_name     String
  credit_logo_url String?
  published_date  String
  category        String
  createdAt       DateTime @default(now())
}

model Exercises {
  exercise_id      Int            @id @default(autoincrement())
  exercise_name    String
  difficulty_level String
  kcal_per_unit    Int
  video_url        String? 
  image_url        String?
  ExercisesLogs    ExercisesLog[]
}

model ExercisesLog {
  ex_log_id         Int       @id @default(autoincrement())
  user              User      @relation(fields: [user_id], references: [user_id])
  user_id           Int
  exercise          Exercises @relation(fields: [exercise_id], references: [exercise_id])
  exercise_id       Int
  step              Int       @default(0)
  total_kcal_burned Float
  log_date          DateTime  @default(now())
}

model StepLog {
  step_id          Int      @id @default(autoincrement())
  user             User     @relation(fields: [user_id], references: [user_id])
  user_id          Int
  steps            Int      @default(0)
  calories_burned  Float    @default(0)
  source           String   @default("Sensor")  //เช้นอร์เอาจากเเอพอื่น 
  log_date         DateTime @default(now())
}