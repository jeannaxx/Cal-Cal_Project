generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  user_Id       String          @id @default(uuid())
  userName      String?
  email         String          @unique
  gender        String
  age           Float
  weight        Float
  height        Float
  userImage     String?
  targetWeight  Float
  planType      String
  weeklyGoal    Float
  calculatedCal Int
  password      String
  exerciseLogs  ExercisesLogs[]
  foodLogs      FoodLogs[]
  walkLogs      Walk[]
}

model Food {
  food_Id   Int        @id @default(autoincrement())
  foodImage String?
  foodName  String
  calories  Int
  unit      String
  category  String
  foodLogs  FoodLogs[]
}

model FoodLogs {
  log_Id        String   @id @default(uuid())
  user_Id       String
  food_Id       Int
  amountEaten   Float
  mealType      String
  logData       DateTime @default(now())
  timeType      DateTime @default(now())
  logImage      String?
  isAiGenerated Boolean  @default(false)
  food          Food     @relation(fields: [food_Id], references: [food_Id])
  user          User     @relation(fields: [user_Id], references: [user_Id])
}

model Exercises {
  ex_Id       Int             @id @default(autoincrement())
  exName      String
  level       String
  kcal        Float
  videoUrl    String?
  exerciseUrl String?
  logs        ExercisesLogs[]
}

model ExercisesLogs {
  exLog_Id  Int       @id @default(autoincrement())
  user_Id   String
  ex_Id     Int
  extype    String
  repsDone  Float
  totalBurn Float
  exData    DateTime  @default(now())
  exercises Exercises @relation(fields: [ex_Id], references: [ex_Id])
  user      User      @relation(fields: [user_Id], references: [user_Id])
}

model Ariricles {
  article_Id  Int      @id @default(autoincrement())
  title       String
  articeLink  String?
  articeimage String?
  creditName  String?
  pushData    DateTime @default(now())
}

model Walk {
  walk_id      Int      @id @default(autoincrement())
  user_Id      String
  stepsCount   Float
  distanceKm   Float
  caloriesBurn Float
  walkData     DateTime @default(now())
  user         User     @relation(fields: [user_Id], references: [user_Id])
}
